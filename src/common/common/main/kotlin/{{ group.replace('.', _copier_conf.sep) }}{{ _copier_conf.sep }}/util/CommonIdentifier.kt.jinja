package {{group}}.util

/**
 * Common interface for resource identifiers across MC versions.
 * Injected into MC's ResourceLocation (1.20.1/1.21.1) and Identifier (26.1) via Mixin.
 */
interface CommonIdentifier {
    val namespace: String
    val path: String

    companion object {
        fun of(namespace: String, path: String): CommonIdentifier =
            IdentifierFactory.create(namespace, path)

        fun parse(value: String): CommonIdentifier =
            IdentifierFactory.parse(value)
    }
}
